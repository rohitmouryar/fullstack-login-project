PORT=4001
CLIENT_URL=http://localhost:5173
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=2h

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=novaauth
DB_USER=novaauth_user
DB_PASSWORD=change-this-database-password

# The first administrator is created automatically on first startup.
ADMIN_NAME=System Administrator
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@123

# Local SentinelFlow SIEM ingestion
SIEM_URL=http://localhost:4000
SIEM_API_KEY=demo-key
